{$SITE_DOMAIN} {

    # --- Training / Capture (port 5001) ---
    handle_path /api/capture/* {
    	reverse_proxy 127.0.0.1:5001
    }

    # --- Heater Control (port 5002) ---
    handle_path /api/heater/* {
    	reverse_proxy 127.0.0.1:5002
    }

    # --- Camera Proxy (port 8080) ---
    # MJPEG streams, focus control, test captures
    handle_path /api/viewfocus/* {
    	reverse_proxy 127.0.0.1:8080
    }

    # --- Prod Server (port 5000) ---
    # Grading pipeline, status polling, diagnostics, cancel, debug image proxy
    #
    # Frontend hits:
    #   POST /api/prod/grade       → start capture + grade
    #   GET  /api/prod/status      → poll progress / result
    #   GET  /api/prod/health      → quick health check
    #   GET  /api/prod/diagnostics → detailed system diagnostics
    #   GET  /api/prod/debug/...   → debug images (proxied from EC2)
    #   POST /api/prod/cancel      → emergency cancel
    #   GET  /api/prod/test        → connectivity test
    #
    # NOTE: handle_path strips "/api/prod" before proxying.
    # So the service on :5000 should expose routes like:
    #   /grade, /status, /health, /diagnostics, /debug/..., /cancel, /test
    handle_path /api/prod/* {
    	reverse_proxy 127.0.0.1:5000
    }

    # --- Fallback ---
    # Anything that doesn't match the routes above goes to the training server.
    # If you later want Caddy to serve your frontend static files from the Pi,
    # replace this with a file_server block.
    handle {
    	reverse_proxy 127.0.0.1:5001
    }

}
