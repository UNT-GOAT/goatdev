[Unit]
Description=Camera Proxy Service
After=network.target

[Service]
ExecStart=/home/pi/venv/bin/gunicorn -w 1 -k geventwebsocket.gunicorn.workers.GeventWebSocketWorker --bind 0.0.0.0:8080 --timeout 300 servers.camera_proxy:app
WorkingDirectory=/home/pi/goatdev/pi
User=root
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target